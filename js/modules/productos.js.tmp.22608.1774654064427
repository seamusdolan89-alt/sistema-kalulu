      7:  { t: 's', z: '@' },
      8:  { t: 's', z: '@' },
      9:  { t: 's', z: '@' },
      10: { t: 'n', z: '0' },
      11: { t: 's', z: '@' },
      12: { t: 's', z: '@' },
      13: { t: 'n', z: '0.##' },
      14: { t: 's', z: '@' },
      15: { t: 's', z: '@' },
      16: { t: 's', z: '@' },
      17: { t: 'n', z: '0' },
      18: { t: 's', z: '@' },
