    let dataRows;
    let filename;
    if (state.productos.length > 0) {
      // Single query: includes madre barcode/nombre (COALESCE self if no madre) + alt-provider name
      const sucursal_id = window.SGA_Auth.getCurrentUser()?.sucursal_id || '1';
      const exportRows = window.SGA_DB.query(`
        SELECT p.*,
          cb.codigo                               AS codigo_barras,
          cat.nombre                              AS categoria_nombre,
          prov.razon_social                       AS proveedor_nombre,
          alt_prov.razon_social                   AS proveedor_alternativo_nombre,
          COALESCE(st.cantidad, 0)                AS stock_actual,
          COALESCE(m.nombre, p.nombre)            AS madre_nombre,
          COALESCE(mc.codigo, cb.codigo, '')      AS madre_codigo,
          sust_ref_cb.codigo                      AS codigo_sustituto_referencia
        FROM productos p
        LEFT JOIN codigos_barras cb       ON cb.producto_id  = p.id    AND cb.es_principal = 1
        LEFT JOIN categorias cat          ON cat.id          = p.categoria_id
        LEFT JOIN proveedores prov        ON prov.id         = p.proveedor_principal_id
        LEFT JOIN proveedores alt_prov    ON alt_prov.id     = p.proveedor_alternativo_id
        LEFT JOIN stock st                ON st.producto_id  = p.id    AND st.sucursal_id = ?
        LEFT JOIN productos m             ON m.id            = p.producto_madre_id
        LEFT JOIN codigos_barras mc       ON mc.producto_id  = m.id    AND mc.es_principal = 1
        LEFT JOIN producto_sustitutos ps_ref ON ps_ref.producto_id = p.id AND ps_ref.referencia_id IS NOT NULL
        LEFT JOIN codigos_barras sust_ref_cb ON sust_ref_cb.producto_id = ps_ref.referencia_id AND sust_ref_cb.es_principal = 1
        ORDER BY p.nombre
      `, [sucursal_id]);

      dataRows = exportRows.map(p => [
        p.codigo_barras || '',
        p.nombre || '',
        p.costo || 0,
        p.precio_venta || 0,
        p.stock_actual || 0,
        p.stock_minimo || 0,
        p.categoria_nombre || '',
        p.proveedor_nombre || '',
        p.codigo_sustituto_referencia || '',
        p.unidad_compra || 'Unidad',
        p.unidades_por_paquete_compra || 1,
        p.unidad_venta || 'Unidad',
        p.precio_lista_por || 'Por unidad de venta',
        p.precio_lista_divisor || 1,
        p.madre_codigo || '',
        p.madre_nombre || '',
        p.proveedor_alternativo_nombre || '',
        p.cant_pedido || 0,
        p.pedido_unidad || ''
      ]);
      filename = 'productos_exportados.xlsx';
    } else {
      dataRows = [['7790001234567', 'Coca Cola 500ml', 350, 550, 24, 6, 'Bebidas', 'Pepsico SA', '', 'Display', 32, 'Unidad', 'Por unidad_compra', 32, '', '', '', 2, 'Display']];
      filename = 'plantilla_productos.xlsx';
    }

    // Instruction row (row 2 in Excel) — guides user on dropdown columns
    const instrRow = Array(19).fill('');
    instrRow[9]  = "→ Ver hoja 'Opciones válidas'";   // J: unidad_compra
    instrRow[11] = "→ Ver hoja 'Opciones válidas'";   // L: unidad_venta
    instrRow[12] = "→ Ver hoja 'Opciones válidas'";   // M: precio_lista_por
    instrRow[18] = "→ Ver hoja 'Opciones válidas'";   // S: pedido_sugerido_unidad

    const ws = XLSX.utils.aoa_to_sheet([headers, instrRow, ...dataRows]);

    // Header cell notes pointing to the options sheet (works in SheetJS CE)
    const headerNotes = {
      J1: 'Valores válidos: ver hoja "Opciones válidas" columna A\n(Unidad, Bulto, Display, Caja, Pack, Bolsa, Kg, Lt, Docena)',
      L1: 'Valores válidos: ver hoja "Opciones válidas" columna B\n(Unidad, Kg, Lt, Por peso, Por fracción)',
      M1: 'Valores válidos: ver hoja "Opciones válidas" columna C\n(Por unidad de venta, Por unidad de compra, Por otra cantidad)',
      S1: 'Valores válidos: ver hoja "Opciones válidas" columna D\n(Unidad, Kg, Bulto cerrado, Pack, Display, Bolsa)',
    };
    Object.entries(headerNotes).forEach(([addr, text]) => {
      if (ws[addr]) ws[addr].c = [{ a: 'SGA', t: text }];
    });

    const range = XLSX.utils.decode_range(ws['!ref']);
    for (let row = 1; row <= range.e.r; row++) {
      Object.keys(colFormats).forEach(c => {
        const cell = ws[XLSX.utils.encode_cell({ r: row, c: Number(c) })];
        if (cell) { cell.t = colFormats[c].t; cell.z = colFormats[c].z; }
      });
    }

    // ── OPCIONES VÁLIDAS SHEET ─────────────────────────────────────────────
    const opcsName = 'Opciones válidas';
    const wsOpts = XLSX.utils.aoa_to_sheet([
      ['Unidad_compra',   'Unidad_venta',   'Precio_lista_por',        'Pedido_unidad'],
      ['Unidad',          'Unidad',          'Por unidad de venta',     'Unidad'],
      ['Bulto',           'Kg',              'Por unidad de compra',    'Kg'],
      ['Display',         'Lt',              'Por otra cantidad',       'Bulto cerrado'],
      ['Caja',            'Por peso',        '',                        'Pack'],
      ['Pack',            'Por fracción',    '',                        'Display'],
      ['Bolsa',           '',                '',                        'Bolsa'],
